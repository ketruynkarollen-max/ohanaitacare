# Copie este arquivo para .env e preencha os valores.
# Nunca commite o arquivo .env no Git.
# Local: cp .env.example .env

# Banco de dados PostgreSQL — Supabase + Prisma
# Definições do projeto → Database → Connection string (URI). Não use token sbp_... aqui.
#
# Opção simples (local / só conexão direta): use a MESMA URI nas duas linhas (porta 5432).
# DATABASE_URL e DIRECT_URL:
#   postgresql://postgres.[PROJECT_REF]:SENHA@db.[PROJECT_REF].supabase.co:5432/postgres
#
# Opção Vercel + pooler: DATABASE_URL = URI Transaction pooler (?pgbouncer=true na porta 6543);
#   DIRECT_URL = URI conexão direta (db.<ref>.supabase.co:5432) — obrigatória para prisma migrate/db push.
DATABASE_URL="postgresql://postgres.PROJECT_REF:SENHA@db.PROJECT_REF.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres.PROJECT_REF:SENHA@db.PROJECT_REF.supabase.co:5432/postgres"

# Autenticação (obrigatório em produção)
# Gerar: openssl rand -base64 64
JWT_SECRET=""

# NextAuth (se usar; gerar: openssl rand -base64 32)
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Push notifications (Web Push / VAPID)
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="mailto:voce@exemplo.com"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# --- Vercel: Settings → Environment Variables ---
# JWT_SECRET        — openssl rand -base64 64
# NEXTAUTH_SECRET   — openssl rand -base64 32
# NEXTAUTH_URL      — ex: https://ohanaitacare.vercel.app (ou seu domínio)
# VAPID_PUBLIC_KEY  — chave pública gerada pelo web-push
# VAPID_PRIVATE_KEY — chave privada gerada pelo web-push
# VAPID_EMAIL       — email de contato (mailto:...)
# NEXT_PUBLIC_VAPID_PUBLIC_KEY — mesma VAPID_PUBLIC_KEY
